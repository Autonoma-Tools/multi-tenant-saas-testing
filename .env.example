# Copy this file to .env and fill in real values, then export them before
# running the fixtures (`set -a; source .env; set +a`).

# Base URL of the multi-tenant app under test (no trailing slash).
BASE_URL=http://localhost:3000

# Privileged admin API token. Used ONLY by fixtures/seedTenants.ts and
# fixtures/teardownTenants.ts to create and delete tenants. Never commit a real
# value; in CI this comes from the ADMIN_API_TOKEN repository secret.
ADMIN_API_TOKEN=replace-with-admin-api-token

# Password assigned to both seeded tenant users, reused by the UI + API login
# flows in the leakage tests.
TENANT_USER_PASSWORD=replace-with-a-strong-password
