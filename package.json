{
  "name": "multi-tenant-saas-testing",
  "version": "0.1.0",
  "private": true,
  "description": "Runnable cross-tenant data-isolation test suite for multi-tenant SaaS.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "seed": "tsx fixtures/seedTenants.ts",
    "teardown": "tsx fixtures/teardownTenants.ts",
    "test:api": "vitest run tests/api",
    "test:jobs": "vitest run tests/jobs",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
